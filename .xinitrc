#!/bin/sh

exec dbus-run-session sh -c '
    cd ~

    dbus-update-activation-environment --all

    if [ -d /etc/X11/xinit/xinitrc.d ]; then
        for f in /etc/X11/xinit/xinitrc.d/?*.sh; do
            [ -x "$f" ] && . "$f"
        done
        unset f
    fi

    # wallpaper + pywal
# >>> wallpaper.sh managed >>>
feh --bg-fill "/home/mibanh/wallpapers/Kita.png" &
wal -i "/home/mibanh/wallpapers/Kita.png" &
# <<< wallpaper.sh managed <<<

    # load Xresources generated by pywal
    [ -f "$HOME/.cache/wal/colors.Xresources" ] && xrdb -merge "$HOME/.cache/wal/colors.Xresources"
    [ -f "$HOME/.cache/wal/xrdb_extra" ] && xrdb -merge "$HOME/.cache/wal/xrdb_extra"

    picom &
    dunst &
    slstatus &
    greenclip daemon &
    fcitx5 -d &
    flameshot &
    redshift &
    /usr/lib/polkit-gnome/polkit-gnome-authentication-agent-1 &
    xautolock -time 10 -notify 10 -notifier 'notify-send "Locking in 10s"' -locker "slock" -detectsleep &
    exec dwm
'
